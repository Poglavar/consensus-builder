{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Consensus Builder API Schema",
    "description": "Complete API schema for the Consensus Builder application",
    "version": "1.0.0",
    "definitions": {
        "PostGISGeometry": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "Point",
                        "LineString",
                        "Polygon",
                        "MultiPoint",
                        "MultiLineString",
                        "MultiPolygon"
                    ]
                },
                "coordinates": {
                    "type": "array",
                    "items": {
                        "type": "number"
                    }
                },
                "crs": {
                    "type": "object",
                    "properties": {
                        "type": {
                            "type": "string"
                        },
                        "properties": {
                            "type": "object",
                            "properties": {
                                "name": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            },
            "required": [
                "type",
                "coordinates"
            ]
        },
        "Parcel": {
            "type": "object",
            "properties": {
                "CESTICA_ID": {
                    "type": "string"
                },
                "BROJ_CESTICE": {
                    "type": "string"
                },
                "geom": {
                    "$ref": "#/definitions/PostGISGeometry"
                },
                "current": {
                    "type": "boolean"
                },
                "is_road": {
                    "type": "boolean"
                },
                "category": {
                    "type": "string"
                },
                "land_use": {
                    "type": "string"
                },
                "maticni_broj_ko": {
                    "type": "string"
                },
                "calculatedArea": {
                    "type": "number"
                },
                "cadastralMunicipality": {
                    "type": "object",
                    "properties": {
                        "id": {
                            "type": "string"
                        },
                        "name": {
                            "type": "string"
                        }
                    }
                }
            },
            "required": [
                "CESTICA_ID",
                "BROJ_CESTICE",
                "geom",
                "current"
            ]
        },
        "Building": {
            "type": "object",
            "properties": {
                "geom": {
                    "$ref": "#/definitions/PostGISGeometry"
                }
            },
            "additionalProperties": true
        },
        "BuildingFootprint": {
            "type": "object",
            "properties": {
                "geometry": {
                    "$ref": "#/definitions/PostGISGeometry"
                },
                "footprint_area": {
                    "type": "number",
                    "description": "Building footprint area in square meters"
                },
                "containment_ratio": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1,
                    "description": "Ratio of building area contained within the parcel (0-1)"
                },
                "cestica_id": {
                    "type": "string",
                    "description": "Parcel ID (CESTICA_ID)"
                },
                "broj_cestice": {
                    "type": "string",
                    "description": "Parcel number (BROJ_CESTICE)"
                }
            },
            "additionalProperties": true,
            "required": [
                "geometry",
                "footprint_area",
                "containment_ratio",
                "cestica_id",
                "broj_cestice"
            ]
        },
        "Building3D": {
            "type": "object",
            "properties": {
                "object_id": {
                    "type": "integer"
                },
                "shape": {
                    "$ref": "#/definitions/PostGISGeometry"
                }
            },
            "additionalProperties": true,
            "required": [
                "object_id",
                "shape"
            ]
        },
        "Street": {
            "type": "object",
            "properties": {
                "geom": {
                    "$ref": "#/definitions/PostGISGeometry"
                }
            },
            "additionalProperties": true
        },
        "PlannedRoad": {
            "type": "object",
            "properties": {
                "geom": {
                    "$ref": "#/definitions/PostGISGeometry"
                },
                "planStatus": {
                    "type": "string"
                },
                "source": {
                    "type": "string"
                },
                "displayColor": {
                    "type": "string"
                },
                "strokeColor": {
                    "type": "string"
                },
                "strokeWeight": {
                    "type": "number"
                },
                "fillOpacity": {
                    "type": "number"
                },
                "display": {
                    "type": "string"
                }
            },
            "additionalProperties": true
        },
        "UrbanRule": {
            "type": "object",
            "properties": {
                "geom_hash": {
                    "type": "string"
                },
                "geom": {
                    "$ref": "#/definitions/PostGISGeometry"
                },
                "title": {
                    "type": "string"
                },
                "short_name": {
                    "type": "string"
                },
                "exception_from": {
                    "type": "string"
                },
                "exception_para": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string",
                    "format": "date-time"
                },
                "updated_at": {
                    "type": "string",
                    "format": "date-time"
                },
                "updated_by": {
                    "type": "string"
                },
                "text_entries": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/UrbanRuleText"
                    }
                }
            },
            "required": [
                "geom_hash",
                "geom",
                "title",
                "short_name",
                "created_at",
                "updated_at",
                "updated_by",
                "text_entries"
            ]
        },
        "UrbanRuleText": {
            "type": "object",
            "properties": {
                "paragraph": {
                    "type": "string"
                },
                "text": {
                    "type": "string"
                },
                "updated_at": {
                    "type": "string",
                    "format": "date-time"
                },
                "updated_by": {
                    "type": "string"
                },
                "analyzed_formatted": {
                    "$ref": "#/definitions/AnalyzedFormattedText"
                }
            }
        },
        "AnalyzedFormattedText": {
            "type": "object",
            "properties": {
                "sections": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/UrbanRuleSection"
                    }
                }
            },
            "required": [
                "sections"
            ]
        },
        "UrbanRuleSection": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Section name (e.g., 'Opća pravila:', 'Detaljna pravila:', 'u zoni ugostiteljsko-turističke namjene:')"
                },
                "sections": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/UrbanRuleSection"
                    },
                    "description": "Nested sections within this section"
                },
                "paragraphs": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/UrbanRuleParagraph"
                    },
                    "description": "Paragraphs within this section"
                }
            },
            "required": [
                "name",
                "sections",
                "paragraphs"
            ]
        },
        "UrbanRuleParagraph": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "description": "Paragraph number (e.g., '1', '2', '3')"
                },
                "text": {
                    "type": "string",
                    "description": "Paragraph text content"
                },
                "isException": {
                    "type": "boolean",
                    "description": "Whether this paragraph is an exception (contains 'iznimno')"
                }
            },
            "required": [
                "name",
                "text",
                "isException"
            ]
        },
        "GeoJSONFeature": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "Feature"
                    ]
                },
                "properties": {
                    "type": "object"
                },
                "geometry": {
                    "$ref": "#/definitions/PostGISGeometry"
                }
            },
            "required": [
                "type",
                "properties",
                "geometry"
            ]
        },
        "GeoJSONFeatureCollection": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "enum": [
                        "FeatureCollection"
                    ]
                },
                "features": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/GeoJSONFeature"
                    }
                }
            },
            "required": [
                "type",
                "features"
            ]
        },
        "UrbanRulesResponse": {
            "type": "object",
            "properties": {
                "coordinates": {
                    "type": "object",
                    "properties": {
                        "x": {
                            "type": "number"
                        },
                        "y": {
                            "type": "number"
                        }
                    },
                    "required": [
                        "x",
                        "y"
                    ]
                },
                "coordinate_system": {
                    "type": "string",
                    "enum": [
                        "WGS84",
                        "HTRS96/TM"
                    ]
                },
                "rule_count": {
                    "type": "integer"
                },
                "urban_rules": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/UrbanRule"
                    }
                }
            },
            "required": [
                "coordinates",
                "coordinate_system",
                "rule_count",
                "urban_rules"
            ]
        },
        "LandUse": {
            "type": "object",
            "properties": {
                "oznaka": {
                    "type": "string",
                    "description": "Land use designation code"
                },
                "namjena": {
                    "type": "string",
                    "description": "Land use purpose"
                },
                "skupna_namjena": {
                    "type": "string",
                    "description": "Collective land use purpose"
                },
                "naziv_plana": {
                    "type": "string",
                    "description": "Plan name"
                },
                "godina_zadnje_izmjene": {
                    "type": "string",
                    "description": "Year of last modification"
                }
            }
        },
        "APIError": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                },
                "details": {
                    "type": "string"
                }
            },
            "required": [
                "error"
            ]
        }
    },
    "paths": {
        "/health": {
            "get": {
                "summary": "Health check endpoint",
                "description": "Returns the health status of the API",
                "responses": {
                    "200": {
                        "description": "API is healthy",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "status": {
                                            "type": "string",
                                            "example": "ok"
                                        }
                                    },
                                    "required": [
                                        "status"
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/docs": {
            "get": {
                "summary": "API Documentation",
                "description": "Returns the main API documentation as HTML",
                "responses": {
                    "200": {
                        "description": "HTML documentation page",
                        "content": {
                            "text/html": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/APIError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/docs/api": {
            "get": {
                "summary": "API Schema Documentation",
                "description": "Returns the OpenAPI-compatible API schema as JSON",
                "responses": {
                    "200": {
                        "description": "OpenAPI schema",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/APIError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/docs/database": {
            "get": {
                "summary": "Database Schema Documentation",
                "description": "Returns live database schema information as JSON",
                "responses": {
                    "200": {
                        "description": "Database schema information",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "title": {
                                            "type": "string"
                                        },
                                        "description": {
                                            "type": "string"
                                        },
                                        "generated_at": {
                                            "type": "string",
                                            "format": "date-time"
                                        },
                                        "database": {
                                            "type": "string"
                                        },
                                        "schema": {
                                            "type": "string"
                                        },
                                        "excluded_patterns": {
                                            "type": "array",
                                            "items": {
                                                "type": "string"
                                            }
                                        },
                                        "tables": {
                                            "type": "object"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/APIError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/land-uses": {
            "get": {
                "summary": "Get land use data by coordinates",
                "description": "Returns planned land use data for the given coordinates. Supports both WGS84 and HTRS96/TM coordinate systems.",
                "parameters": [
                    {
                        "name": "coordinates",
                        "in": "query",
                        "description": "Point coordinates as x,y (WGS84 or EPSG:3765)",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "pattern": "^[0-9.-]+,[0-9.-]+$"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "GeoJSON FeatureCollection of land use data",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "type": {
                                            "type": "string",
                                            "enum": [
                                                "FeatureCollection"
                                            ]
                                        },
                                        "features": {
                                            "type": "array",
                                            "items": {
                                                "type": "object",
                                                "properties": {
                                                    "type": {
                                                        "type": "string",
                                                        "enum": [
                                                            "Feature"
                                                        ]
                                                    },
                                                    "properties": {
                                                        "$ref": "#/definitions/LandUse"
                                                    },
                                                    "geometry": {
                                                        "$ref": "#/definitions/PostGISGeometry"
                                                    }
                                                },
                                                "required": [
                                                    "type",
                                                    "properties",
                                                    "geometry"
                                                ]
                                            }
                                        }
                                    },
                                    "required": [
                                        "type",
                                        "features"
                                    ]
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad request - invalid coordinates or missing parameter",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/APIError"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/APIError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/parcel-ba": {
            "get": {
                "summary": "Get Buenos Aires parcels by SMP, block, or section",
                "description": "Returns Buenos Aires parcel data as GeoJSON. Provide either `smp` for a single parcel, `section`+`block` (optionally `parcel`) for a manzana, or only `section` for the full section.",
                "parameters": [
                    {
                        "name": "smp",
                        "in": "query",
                        "description": "Unique SMP identifier for a single parcel",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "section",
                        "in": "query",
                        "description": "Section identifier",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "block",
                        "in": "query",
                        "description": "Block (manzana) identifier, requires section",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "parcel",
                        "in": "query",
                        "description": "Parcel identifier within a section/block combination",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "description": "Optional cap for block/section queries (max 5000)",
                        "required": false,
                        "schema": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 5000
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "GeoJSON FeatureCollection of Buenos Aires parcels",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/GeoJSONFeatureCollection"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad request - invalid or missing filter combination",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/APIError"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "No parcels found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/APIError"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/APIError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/parcels": {
            "get": {
                "summary": "Get parcels by bbox, coordinates, or parcel number",
                "parameters": [
                    {
                        "name": "bbox",
                        "in": "query",
                        "description": "Bounding box as minX,minY,maxX,maxY in EPSG:3765",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "coordinates",
                        "in": "query",
                        "description": "Point coordinates as x,y (WGS84 or EPSG:3765)",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "parcel_number",
                        "in": "query",
                        "description": "Parcel number (BROJ_CESTICE)",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "GeoJSON FeatureCollection of parcels",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/GeoJSONFeatureCollection"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/APIError"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/APIError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/buildings": {
            "get": {
                "summary": "Get buildings by bounding box or parcel ID",
                "description": "Returns buildings either by bounding box (original functionality) or buildings mostly contained within a specific parcel (90% containment threshold)",
                "parameters": [
                    {
                        "name": "bbox",
                        "in": "query",
                        "description": "Bounding box as minX,minY,maxX,maxY in EPSG:3765",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "cestica_id",
                        "in": "query",
                        "description": "Parcel ID (CESTICA_ID) to get buildings mostly contained within the parcel",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "GeoJSON FeatureCollection of buildings or building footprints",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "oneOf": [
                                        {
                                            "$ref": "#/definitions/GeoJSONFeatureCollection"
                                        },
                                        {
                                            "type": "object",
                                            "properties": {
                                                "type": {
                                                    "type": "string",
                                                    "enum": [
                                                        "FeatureCollection"
                                                    ]
                                                },
                                                "features": {
                                                    "type": "array",
                                                    "items": {
                                                        "type": "object",
                                                        "properties": {
                                                            "type": {
                                                                "type": "string",
                                                                "enum": [
                                                                    "Feature"
                                                                ]
                                                            },
                                                            "properties": {
                                                                "$ref": "#/definitions/BuildingFootprint"
                                                            },
                                                            "geometry": {
                                                                "$ref": "#/definitions/PostGISGeometry"
                                                            }
                                                        },
                                                        "required": [
                                                            "type",
                                                            "properties",
                                                            "geometry"
                                                        ]
                                                    }
                                                },
                                                "cestica_id": {
                                                    "type": "string",
                                                    "description": "The parcel ID that was queried"
                                                },
                                                "count": {
                                                    "type": "integer",
                                                    "description": "Number of buildings found"
                                                }
                                            },
                                            "required": [
                                                "type",
                                                "features",
                                                "cestica_id",
                                                "count"
                                            ]
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad request - invalid parameters",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/APIError"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/APIError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/objects": {
            "get": {
                "summary": "Get 3D building objects by geometry",
                "parameters": [
                    {
                        "name": "geometry",
                        "in": "query",
                        "description": "JSON geometry object",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "GeoJSON FeatureCollection of 3D buildings",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/GeoJSONFeatureCollection"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/APIError"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "No objects found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/APIError"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/definitions/APIError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/planned-road": {
            "get": {
                "summary": "Get planned roads by bounding box",
                "parameters": [
                    {
                        "name": "bbox",
                        "in": "query",
                        "description": "Bounding box as minX,minY,maxX,maxY in EPSG:3765",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
